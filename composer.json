{
    "name": "cm-mike/laravel-mpesa-stk",
    "description": "A streamlined Laravel package for M-Pesa STK Push integrations.",
    "type": "library",
    "license": "MIT",
    "authors": [
        {
            "name": "Churchill Mikes",
            "email": "awirotieno@gmail.com"
        }
    ],
    "require": {
        "php": "^8.1",
        "illuminate/support": "^10.0|^11.0",
        "guzzlehttp/guzzle": "^7.0"
    },
    "autoload": {
        "psr-4": {
            "CMMike\\MpesaStk\\": "src/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "CMMike\\MpesaStk\\MpesaServiceProvider"
            ],
            "aliases": {
                "Mpesa": "CMMike\\MpesaStk\\Facades\\Mpesa"
            }
        }
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}